    "# else:\n",
    "#     print('CLEAR_OUTPUT_DIR is False; keeping existing OUTPUT_DIR contents.')\n",
    "#     if OUTPUT_DIR.exists():\n",
    "#         existing = sorted(OUTPUT_DIR.iterdir())\n",
